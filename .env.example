# AWS Amplify Configuration
VITE_AWS_REGION=us-east-1
VITE_AWS_USER_POOL_ID=your-user-pool-id
VITE_AWS_USER_POOL_CLIENT_ID=your-user-pool-client-id
VITE_AWS_GRAPHQL_ENDPOINT=your-graphql-endpoint
VITE_AWS_S3_BUCKET=your-s3-bucket-name

# Environment
VITE_ENV=development

# Monitoring and Analytics Configuration
# Sentry Error Tracking (Requirement 9.3)
VITE_SENTRY_DSN=your-sentry-dsn
VITE_ENABLE_ERROR_TRACKING=false
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# CloudWatch Integration (Requirement 9.4)
VITE_ENABLE_CLOUDWATCH=false

# Analytics Tracking (Requirement 9.4)
VITE_ENABLE_ANALYTICS=false

# Application Version (for release tracking)
VITE_APP_VERSION=1.0.0
